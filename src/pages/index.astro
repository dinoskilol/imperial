---
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import imperialLogo from '../assets/imperial-logo.png';
import heroRestaurant from '../assets/real/f0373e7a-dafc-4c29-8841-7ae743a942e3.jpg';
import heroMobileRestaurant from '../assets/real/f2c06b97-a3a4-4d08-b9e9-6f777d8090a3.jpg';
import aboutRestaurant from '../assets/real/5100bb98-5bf2-485f-b718-29cd9c28df16.jpg';
import menuOven from '../assets/real/a6a417e9-b1e3-47de-bef2-5dc06966f844.jpg';
import galleryDetail from '../assets/real/3a07d28c-e66a-4303-8723-6190150e7310.jpg';
import galleryDining from '../assets/real/43880e31-1864-474e-8a09-14d61e7000fd.jpg';
import galleryCellar from '../assets/real/e12dddec-1fb1-4891-a99b-739488647598.jpg';
import eventsRestaurant from '../assets/real/03de8193-4f05-4a84-af3d-2b536cc94212.jpg';
import { content } from '../data/content';
import { siteConfig } from '../data/site';

const copy = content.de;
const basePath = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const flagUrl = (code: string) => `${basePath}flags/${code}.svg`;
const menuPdfUrl = `${basePath}imperial-menu.pdf`;
const heroMobileSource = await getImage({ src: heroMobileRestaurant, width: 780, format: 'webp', quality: 88 });
---

<BaseLayout title={copy.meta.title} description={copy.meta.description}>
  <a class="skip-link" href="#main">Zum Inhalt springen</a>

  <header class="site-header" data-header>
    <a class="wordmark" href="#top" aria-label="Imperial – Startseite">
      <Image class="wordmark__image" src={imperialLogo} alt="" width={92} height={92} quality={84} loading="eager" />
    </a>

    <nav class="desktop-nav" aria-label="Hauptnavigation">
      <a href="#about" data-i18n="nav.about">{copy.nav.about}</a>
      <a href="#menu" data-i18n="nav.menu">{copy.nav.menu}</a>
      <a href="#events" data-i18n="nav.events">{copy.nav.events}</a>
      <a class="nav-cta" href="#reserve" data-i18n="nav.reserve">{copy.nav.reserve}</a>
    </nav>

    <div class="header-actions">
      <div class="language-switcher" aria-label="Sprache wählen">
        <button class="is-active" type="button" data-language-switch="de" aria-pressed="true" aria-label="Deutsch"><img src={flagUrl('de')} alt="" /></button>
        <button type="button" data-language-switch="fr" aria-pressed="false" aria-label="Français"><img src={flagUrl('fr')} alt="" /></button>
        <button type="button" data-language-switch="it" aria-pressed="false" aria-label="Italiano"><img src={flagUrl('it')} alt="" /></button>
        <button type="button" data-language-switch="en" aria-pressed="false" aria-label="English"><img src={flagUrl('gb')} alt="" /></button>
      </div>
      <a class="mobile-reserve" href="#reserve" data-i18n="nav.reserve">{copy.nav.reserve}</a>
      <button class="menu-toggle" type="button" aria-controls="mobile-nav" aria-expanded="false" aria-label={copy.nav.open} data-menu-toggle>
        <span></span><span></span>
      </button>
    </div>

    <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile Navigation" hidden>
      <a href="#about" data-i18n="nav.about">{copy.nav.about}</a>
      <a href="#menu" data-i18n="nav.menu">{copy.nav.menu}</a>
      <a href="#events" data-i18n="nav.events">{copy.nav.events}</a>
      <a href="#reserve" data-i18n="nav.reserve">{copy.nav.reserve}</a>
      <div class="mobile-nav__languages" aria-label="Sprache wählen">
        <button class="is-active" type="button" data-language-switch="de" aria-pressed="true" aria-label="Deutsch"><img src={flagUrl('de')} alt="" /><span>DE</span></button>
        <button type="button" data-language-switch="fr" aria-pressed="false" aria-label="Français"><img src={flagUrl('fr')} alt="" /><span>FR</span></button>
        <button type="button" data-language-switch="it" aria-pressed="false" aria-label="Italiano"><img src={flagUrl('it')} alt="" /><span>IT</span></button>
        <button type="button" data-language-switch="en" aria-pressed="false" aria-label="English"><img src={flagUrl('gb')} alt="" /><span>EN</span></button>
      </div>
    </nav>
  </header>

  <main id="main">
    <section class="hero" id="top" aria-labelledby="hero-title">
      <div class="hero__backdrop" aria-hidden="true">
        <picture>
          <source media="(max-width: 800px)" srcset={heroMobileSource.src} />
          <Image src={heroRestaurant} alt="" widths={[960, 1440, 1920]} sizes="100vw" quality={88} loading="eager" />
        </picture>
      </div>
      <div class="hero__copy">
        <p class="eyebrow" data-i18n="hero.eyebrow">{copy.hero.eyebrow}</p>
        <h1 id="hero-title" data-i18n="hero.title">{copy.hero.title}</h1>
        <p class="hero__intro" data-i18n="hero.subtitle">{copy.hero.subtitle}</p>
        <div class="hero__actions">
          <a class="button button--gold" href="#reserve" data-i18n="hero.primary">{copy.hero.primary}</a>
          <a class="text-link" href="#menu"><span data-i18n="hero.secondary">{copy.hero.secondary}</span><span aria-hidden="true">↘</span></a>
        </div>
        <div class="hero__seal" aria-hidden="true">
          <img class="hero__flag hero__flag--ch" src={flagUrl('ch')} alt="" />
          <i></i>
          <img class="hero__flag hero__flag--it" src={flagUrl('it')} alt="" />
        </div>
      </div>

      <a class="hero__scroll" href="#about">
        <span data-i18n="hero.scroll">{copy.hero.scroll}</span>
        <span aria-hidden="true">↓</span>
      </a>
    </section>

    <section class="about section" id="about" aria-labelledby="about-title">
      <div class="about__image reveal">
        <Image src={aboutRestaurant} alt="Blick durch den Weineingang in den Gastraum des Imperial" widths={[480, 720, 960, 1280]} sizes="(max-width: 800px) 100vw, 50vw" quality={86} />
        <div class="image-note"><span>46° N</span><span>Swiss Italian</span></div>
      </div>
      <div class="about__copy reveal">
        <p class="eyebrow eyebrow--dark" data-i18n="about.eyebrow">{copy.about.eyebrow}</p>
        <h2 id="about-title" data-i18n="about.title">{copy.about.title}</h2>
        <p class="body-copy" data-i18n="about.body">{copy.about.body}</p>
        <blockquote data-i18n="about.quote">{copy.about.quote}</blockquote>
        <p class="detail-line"><span></span><span data-i18n="about.detail">{copy.about.detail}</span></p>
      </div>
    </section>

    <section class="menu section" id="menu" aria-labelledby="menu-title">
      <div class="menu__feature">
        <div class="menu__photo reveal">
          <Image src={menuOven} alt="Holzbefeuerter Pizzaofen in der Küche des Imperial" widths={[640, 960, 1280]} sizes="(max-width: 800px) 100vw, 58vw" quality={88} />
          <span class="menu__photo-label">Fatto a mano</span>
        </div>
        <div class="menu__panel reveal">
          <p class="eyebrow" data-i18n="menu.eyebrow">{copy.menu.eyebrow}</p>
          <h2 id="menu-title" data-i18n="menu.title">{copy.menu.title}</h2>
          <p data-i18n="menu.intro">{copy.menu.intro}</p>
          <a class="button button--gold" href={menuPdfUrl} download="Imperial-Speisekarte.pdf">
            <span data-i18n="menu.download">{copy.menu.download}</span>
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 3v12m0 0 5-5m-5 5-5-5M5 21h14" /></svg>
          </a>
        </div>
      </div>
    </section>

    <section class="gallery section" aria-labelledby="gallery-title">
      <div class="section-heading reveal">
        <div>
          <p class="eyebrow eyebrow--dark" data-i18n="gallery.eyebrow">{copy.gallery.eyebrow}</p>
          <h2 id="gallery-title" data-i18n="gallery.title">{copy.gallery.title}</h2>
        </div>
        <p data-i18n="gallery.intro">{copy.gallery.intro}</p>
      </div>
      <div class="gallery__grid reveal" data-gallery-grid>
        <figure class="gallery-card gallery-card--detail">
          <Image src={galleryDetail} alt="Weinfass und italienische Details im Imperial" widths={[480, 720, 960]} sizes="(max-width: 800px) 78vw, 29vw" quality={86} />
          <figcaption><span>01</span><span data-i18n="gallery.items.0">{copy.gallery.items[0]}</span></figcaption>
        </figure>
        <figure class="gallery-card gallery-card--wide">
          <Image src={galleryDining} alt="Einladender Gastraum mit gedeckten Tischen im Imperial" widths={[640, 960, 1280]} sizes="(max-width: 800px) 78vw, 40vw" quality={86} />
          <figcaption><span>02</span><span data-i18n="gallery.items.1">{copy.gallery.items[1]}</span></figcaption>
        </figure>
        <figure class="gallery-card gallery-card--cellar">
          <Image src={galleryCellar} alt="Italienische Weine im Weinkeller des Imperial" widths={[480, 720, 960]} sizes="(max-width: 800px) 78vw, 29vw" quality={86} />
          <figcaption><span>03</span><span data-i18n="gallery.items.2">{copy.gallery.items[2]}</span></figcaption>
        </figure>
      </div>
      <div class="gallery-controls" data-gallery-controls>
        <button type="button" data-gallery-previous data-i18n-label="gallery.previous" aria-label={copy.gallery.previous}><span aria-hidden="true">←</span></button>
        <p aria-live="polite"><span data-i18n="gallery.counter">{copy.gallery.counter}</span> <span data-gallery-status>1 / 3</span></p>
        <button type="button" data-gallery-next data-i18n-label="gallery.next" aria-label={copy.gallery.next}><span aria-hidden="true">→</span></button>
      </div>
    </section>

    <section class="events section" id="events" aria-labelledby="events-title">
      <div class="events__backdrop" aria-hidden="true">
        <Image src={eventsRestaurant} alt="" widths={[960, 1440, 1920]} sizes="100vw" quality={84} />
      </div>
      <div class="events__inner">
        <div class="section-heading section-heading--light reveal">
          <div>
            <p class="eyebrow" data-i18n="events.eyebrow">{copy.events.eyebrow}</p>
            <h2 id="events-title" data-i18n="events.title">{copy.events.title}</h2>
          </div>
          <p data-i18n="events.intro">{copy.events.intro}</p>
        </div>
        <div class="event-grid reveal" data-event-grid>
          {copy.events.items.map((event) => (
            <article class="event-card">
              <div class="event-card__top"><span>{event.number}</span><span>{copy.events.recurring}</span></div>
              <p class="event-card__date">{event.cadence}</p>
              <h3>{event.title}</h3>
              <p>{event.description}</p>
              <a href="#reserve"><span>{copy.events.reserve}</span><span aria-hidden="true">↗</span></a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="reservation section" id="reserve" aria-labelledby="reserve-title">
      <div class="reservation__intro reveal">
        <p class="eyebrow eyebrow--dark" data-i18n="reserve.eyebrow">{copy.reserve.eyebrow}</p>
        <h2 id="reserve-title" data-i18n="reserve.title">{copy.reserve.title}</h2>
        <p data-i18n="reserve.intro">{copy.reserve.intro}</p>
        <div class="reservation__monogram" aria-hidden="true">I</div>
        <p class="reservation__notice"><span aria-hidden="true">✦</span><span data-i18n="reserve.notice">{copy.reserve.notice}</span></p>
      </div>
      <form class="restaurant-form reveal" id="reservation-form">
        <div class="field field--wide">
          <label for="reservation-name" data-i18n="reserve.fields.name">{copy.reserve.fields.name}</label>
          <input id="reservation-name" name="name" type="text" required autocomplete="name" placeholder={copy.reserve.placeholders.name} data-placeholder="reserve.placeholders.name" />
        </div>
        <div class="field">
          <label for="reservation-email" data-i18n="reserve.fields.email">{copy.reserve.fields.email}</label>
          <input id="reservation-email" name="email" type="email" required autocomplete="email" placeholder={copy.reserve.placeholders.email} data-placeholder="reserve.placeholders.email" />
        </div>
        <div class="field">
          <label for="reservation-phone" data-i18n="reserve.fields.phone">{copy.reserve.fields.phone}</label>
          <input id="reservation-phone" name="phone" type="tel" autocomplete="tel" placeholder={copy.reserve.placeholders.phone} data-placeholder="reserve.placeholders.phone" />
        </div>
        <div class="field">
          <label for="reservation-date" data-i18n="reserve.fields.date">{copy.reserve.fields.date}</label>
          <input id="reservation-date" name="date" type="date" required data-min-date />
        </div>
        <div class="field">
          <label for="reservation-time" data-i18n="reserve.fields.time">{copy.reserve.fields.time}</label>
          <input id="reservation-time" name="time" type="time" required />
        </div>
        <div class="field">
          <label for="reservation-guests" data-i18n="reserve.fields.guests">{copy.reserve.fields.guests}</label>
          <input id="reservation-guests" name="guests" type="number" min="1" max="12" value="2" required />
        </div>
        <div class="field field--wide">
          <label for="reservation-message" data-i18n="reserve.fields.message">{copy.reserve.fields.message}</label>
          <textarea id="reservation-message" name="message" rows="3" placeholder={copy.reserve.placeholders.message} data-placeholder="reserve.placeholders.message"></textarea>
        </div>
        <div class="form-submit field--wide">
          <button class="button button--green" type="submit"><span data-i18n="reserve.submit">{copy.reserve.submit}</span><span aria-hidden="true">↗</span></button>
          <p class="form-status" data-reservation-status aria-live="polite"></p>
        </div>
      </form>
    </section>

    <section class="contact section" id="contact" aria-labelledby="contact-title">
      <div class="contact__details reveal">
        <div class="contact__heading">
          <div>
            <p class="eyebrow" data-i18n="contact.eyebrow">{copy.contact.eyebrow}</p>
            <h2 id="contact-title" data-i18n="contact.title">{copy.contact.title}</h2>
          </div>
          <p data-i18n="contact.intro">{copy.contact.intro}</p>
        </div>
        <div class="contact__grid">
          <div class="contact-list">
            <div><span data-i18n="contact.address">{copy.contact.address}</span><address>{siteConfig.address}</address></div>
            <div><span data-i18n="contact.phone">{copy.contact.phone}</span><a href={`tel:${siteConfig.phoneHref}`}>{siteConfig.phoneDisplay}</a></div>
            <div><span data-i18n="contact.email">{copy.contact.email}</span><a href={`mailto:${siteConfig.contactEmail}`}>{siteConfig.contactEmail}</a></div>
          </div>
          <div class="hours">
            <h3 data-i18n="contact.hours">{copy.contact.hours}</h3>
            <div data-hours-list>
              {copy.contact.hoursRows.map(([day, time]) => <p><span>{day}</span><span>{time}</span></p>)}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-brand">
      <Image class="footer-logo" src={imperialLogo} alt="Imperial Restaurant & Pizzeria" width={170} quality={84} />
      <p data-i18n="footer.tagline">{copy.footer.tagline}</p>
    </div>
    <div>
      <h2 data-i18n="footer.navigation">{copy.footer.navigation}</h2>
      <a href="#about" data-i18n="nav.about">{copy.nav.about}</a>
      <a href="#menu" data-i18n="nav.menu">{copy.nav.menu}</a>
      <a href="#events" data-i18n="nav.events">{copy.nav.events}</a>
      <a href="#reserve" data-i18n="nav.reserve">{copy.nav.reserve}</a>
    </div>
    <div>
      <h2 data-i18n="footer.contact">{copy.footer.contact}</h2>
      <a href={`mailto:${siteConfig.contactEmail}`}>{siteConfig.contactEmail}</a>
      <a href={`tel:${siteConfig.phoneHref}`}>{siteConfig.phoneDisplay}</a>
      <span>{siteConfig.address}</span>
    </div>
    <a class="back-to-top" href="#top"><span data-i18n="footer.top">{copy.footer.top}</span><span aria-hidden="true">↑</span></a>
    <p class="footer-demo" data-i18n="footer.demo">{copy.footer.demo}</p>
  </footer>

  <script>
    import '../scripts/site';
  </script>
</BaseLayout>
